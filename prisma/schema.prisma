// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum EmployeeStatus {
    CREATED
    ENROLLED
    ACTIVE
    INACTIVE
}

enum AttendanceType {
    CHECK_IN
    CHECK_OUT
}

enum AttendanceStatus {
    VALID
    REJECTED
    LATE
    EARLY_LEAVE
    OVERTIME
}

model Admin {
    id           String @id @default(uuid()) @db.Uuid
    username     String @unique @db.VarChar(100)
    email        String @unique @db.VarChar(255)
    passwordHash String @map("password")
    fullName     String @map("full_name") @db.VarChar(255)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("admins")
}

model Shift {
    id                   String   @id @default(uuid()) @db.Uuid
    name                 String   @unique
    startTime            DateTime @db.Time
    endTime              DateTime @db.Time
    timezone             String
    lateToleranceMinutes Int      @default(0) @map("late_tolerance_minutes")

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    employees   Employee[]
    attendances Attendance[]

    @@map("shifts")
}

model Employee {
    id           String  @id @default(uuid()) @db.Uuid
    employeeCode String  @unique @map("employee_code") @db.VarChar(50)
    fullName     String  @map("full_name") @db.VarChar(255)
    email        String? @unique @db.VarChar(255)
    rfidUid      String? @unique @map("rfid_uid") @db.VarChar(100)

    status EmployeeStatus

    shiftId String? @map("shift_id") @db.Uuid
    shift   Shift?  @relation(fields: [shiftId], references: [id], onDelete: Restrict)

    faceEmbeddings FaceEmbedding[]
    attendances    Attendance[]

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    @@index([status])
    @@index([shiftId])
    @@map("employees")
}

model FaceEmbedding {
    id String @id @default(uuid()) @db.Uuid

    employeeId String   @map("employee_id") @db.Uuid
    employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

    embedding    Json
    sampleNumber Int  @map("sample_number")

    createdAt DateTime @default(now()) @map("created_at")

    @@index([employeeId])
    @@map("face_embeddings")
}

model Device {
    id String @id @default(uuid()) @db.Uuid

    deviceId   String @unique @map("device_id")
    deviceName String @map("device_name")
    secretHash String @map("secret_hash")

    isWhitelisted Boolean @default(true) @map("is_whitelisted")

    attendances Attendance[]

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    @@index([isWhitelisted])
    @@map("devices")
}

model Attendance {
    id String @id @default(uuid()) @db.Uuid

    employeeId String   @map("employee_id") @db.Uuid
    employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

    deviceId String @map("device_id") @db.Uuid
    device   Device @relation(fields: [deviceId], references: [id], onDelete: Restrict)

    shiftId String @map("shift_id") @db.Uuid
    shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Restrict)

    attendanceDate DateTime @map("attendance_date") @db.Date

    attendanceType AttendanceType   @map("attendance_type")
    status         AttendanceStatus

    checkTime DateTime @map("check_time")

    faceSimilarity Decimal? @map("face_similarity") @db.Decimal(5, 4)

    imageUrl String? @map("image_url")

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([employeeId, attendanceDate, attendanceType])
    @@index([employeeId])
    @@index([deviceId])
    @@index([attendanceDate])
    @@map("attendance")
}
